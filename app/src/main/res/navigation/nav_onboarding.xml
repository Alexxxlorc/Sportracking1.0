<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_onboarding"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="onboarding.SignIn.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment_to_recuperacionfragment"
            app:destination="@id/recuperacionfragment" />

    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="onboarding.signUp.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_registerFragment_to_infoPersonalFragment"
            app:destination="@id/infoPersonalFragment" />

    </fragment>

    <fragment
        android:id="@+id/infoPersonalFragment"
        android:name="onboarding.personal.InfoPersonalFragment"
        android:label="fragment_info_personal"
        tools:layout="@layout/fragment_info_personal" />

    <fragment
        android:id="@+id/recuperacionfragment"
        android:name="com.example.sportracking.Recuperacionfragment"
        android:label="Recuperacionfragment"
        tools:layout="@layout/fragment_recuperacion" >
        <action
            android:id="@+id/action_recuperacionfragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

</navigation>
